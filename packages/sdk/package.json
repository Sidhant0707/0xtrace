{
  "name": "0xtrace",
  "version": "1.1.1",
  "description": "AI observability and PromptOps infrastructure for LLM applications.",
  "author": "Sidhant Kumar <buildwithsidhant@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sidhant0707/0xtrace.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://0xtrace-mu.vercel.app",
  "bugs": {
    "url": "https://github.com/Sidhant0707/0xtrace/issues"
  },
  "keywords": [
    "llm",
    "observability",
    "openai",
    "promptops",
    "tracing",
    "agents",
    "telemetry"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && tsc --project tsconfig.build.json",
    "prepublishOnly": "cp ../../README.md ."
  },
  "dependencies": {
    "diff": "^9.0.0",
    "openai": "^6.38.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "cac": "^6.7.14",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
