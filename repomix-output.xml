    tokens: [
      "const ",
      "res ",
      "= await ",
      "ai.chat.completions.",
      "create",
      "({",
    ],
    colors: ["tok-c1", "tok-c4", "tok-c1", "tok-c3", "tok-c2", "tok-c3"],
