interface TraceRow {
  id: string;
  session: string;
  model: string;
  steps: number;
  cost: string;
  ms: number;
  status: "ok" | "anomaly";
}

const FEED_ROWS: TraceRow[] = [
  {
    id: "1",
    session: "sess-a3f1",
    model: "gpt-4o",
