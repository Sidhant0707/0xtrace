          </div>
        </FadeIn>
      </div>
      <style jsx>{`
        .tok-c1 {
          color: #71717a;
        }
        .tok-c2 {
          color: #e4e4e7;
        }
        .tok-c3 {
          color: #a1a1aa;
        }
        .tok-c4 {
          color: #60a5fa;
        }
        .tok-c5 {
          color: #52525b;
        }
      `}</style>
    </section>
  );
}

